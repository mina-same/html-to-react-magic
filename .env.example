# ─── Supabase ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── OpenAI — server-side only, NO VITE_ prefix ─────────────────
# Used by caption-server only. Never expose this to the browser.
OPENAI_API_KEY=sk-...

# ─── Caption server ───────────────────────────────────────────────
CAPTION_SERVER_PORT=3001
VITE_CAPTION_API_URL=http://localhost:3001

# Storage directory for uploaded videos, audio, captions, and renders
PROJECT_STORAGE_DIR=./storage/projects

# Upload size limit in MB
MAX_UPLOAD_SIZE_MB=500

# How long to keep completed projects (hours)
PROJECT_RETENTION_HOURS=24

# Concurrency limits
MAX_CONCURRENT_TRANSCRIPTIONS=2
MAX_CONCURRENT_RENDERS=1

# Optional: override auto-detected FFmpeg/FFprobe binaries
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFPROBE_PATH=/usr/local/bin/ffprobe
